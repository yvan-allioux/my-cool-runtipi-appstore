{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "aurral",
      "image": "ghcr.io/lklynet/aurral:1.23.0",
      "isMain": true,
      "internalPort": 3001,
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data",
          "containerPath": "/app/backend/data"
        }
      ],
      "environment": [
        {
          "key": "PUID",
          "value": "${PUID:-1000}"
        },
        {
          "key": "PGID",
          "value": "${PGID:-1000}"
        },
        {
          "key": "TRUST_PROXY",
          "value": "1"
        }
      ]
    }
  ]
}
