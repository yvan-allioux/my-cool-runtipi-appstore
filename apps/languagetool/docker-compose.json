{
  "schemaVersion": 2,
  "$schema": "https://schemas.runtipi.io/dynamic-compose.json",
  "services": [
    {
      "name": "languagetool",
      "image": "erikvl87/languagetool:6.7",
      "isMain": true,
      "internalPort": 8010,
      "volumes": [
        {
          "hostPath": "${APP_DATA_DIR}/data/ngrams",
          "containerPath": "/ngrams"
        }
      ],
      "environment": [
        {
          "key": "Java_Xms",
          "value": "${JAVA_XMS:-512m}"
        },
        {
          "key": "Java_Xmx",
          "value": "${JAVA_XMX:-1g}"
        },
        {
          "key": "langtool_languageModel",
          "value": "/ngrams"
        },
        {
          "key": "langtool_pipelinePrewarming",
          "value": "true"
        }
      ]
    }
  ]
}
